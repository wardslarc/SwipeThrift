{
  "name": "swipethrift-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "npm run knex migrate:latest && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "knex": "knex --knexfile src/database/knexfile.ts"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "morgan": "1.10.0",
    "mysql2": "3.9.7",
    "redis": "4.6.13",
    "socket.io": "4.7.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5",
    "typescript-eslint": "^8.59.0"
  }
}
